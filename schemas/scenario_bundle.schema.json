{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orbital-shepherd://schemas/v0.1/scenario_bundle.schema.json",
  "title": "ScenarioBundle",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "benchmark_id",
    "scenario_family",
    "simulation_seed",
    "decision_interval_seconds",
    "time_window",
    "satellites",
    "ground_stations",
    "target_cells",
    "incidents",
    "config"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "benchmark_id": {
      "type": "string"
    },
    "scenario_family": {
      "type": "string"
    },
    "simulation_seed": {
      "type": "integer"
    },
    "decision_interval_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "time_window": {
      "type": "object",
      "required": [
        "start_time_utc",
        "end_time_utc"
      ],
      "properties": {
        "start_time_utc": {
          "type": "string",
          "format": "date-time"
        },
        "end_time_utc": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "satellites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://schemas/v0.1/satellite.schema.json"
      }
    },
    "ground_stations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://schemas/v0.1/ground_station.schema.json"
      }
    },
    "target_cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://schemas/v0.1/target_cell.schema.json"
      }
    },
    "incidents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://schemas/v0.1/incident.schema.json"
      }
    },
    "config": {
      "type": "object",
      "required": [
        "horizon_hours",
        "notes",
        "weather_model",
        "opportunity_generation"
      ],
      "properties": {
        "horizon_hours": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        },
        "weather_model": {
          "type": "string"
        },
        "opportunity_generation": {
          "type": "object",
          "required": [
            "quality_threshold",
            "cloud_block_threshold"
          ],
          "properties": {
            "quality_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "cloud_block_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}