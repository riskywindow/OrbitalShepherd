{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orbital-shepherd://contracts/v1.0/tactical_scenario_bundle.schema.json",
  "title": "TacticalScenarioBundle",
  "description": "Compiled immutable tactical runtime artifact derived from a TacticalScenarioManifest.",
  "type": "object",
  "required": [
    "schema_version",
    "tactical_bundle_id",
    "bundle_fingerprint",
    "tactical_manifest_id",
    "activation_id",
    "incident_packet_id",
    "region_bundle_id",
    "scenario_family",
    "simulation_seed",
    "decision_interval_seconds",
    "time_window",
    "incident_packet",
    "dispatch_units",
    "facilities",
    "route_plans",
    "config",
    "compilation"
  ],
  "properties": {
    "schema_version": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/schemaVersion"
    },
    "tactical_bundle_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "bundle_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "tactical_manifest_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "activation_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "incident_packet_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "region_bundle_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "scenario_family": {
      "type": "string",
      "minLength": 1
    },
    "simulation_seed": {
      "type": "integer"
    },
    "decision_interval_seconds": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveInteger"
    },
    "time_window": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/timeWindow"
    },
    "incident_packet": {
      "$ref": "orbital-shepherd://contracts/v1.0/incident_packet.schema.json"
    },
    "dispatch_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/dispatch_unit.schema.json"
      }
    },
    "facilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/facility.schema.json"
      }
    },
    "route_plans": {
      "type": "array",
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/route_plan.schema.json"
      }
    },
    "config": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/tacticalScenarioConfig"
    },
    "compilation": {
      "type": "object",
      "required": [
        "source_manifest_id",
        "source_manifest_schema_version",
        "source_manifest_sha256",
        "compiled_at_utc",
        "compiler_version"
      ],
      "properties": {
        "source_manifest_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "source_manifest_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "source_manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "compiled_at_utc": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/utcTimestamp"
        },
        "compiler_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
