{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orbital-shepherd://contracts/v1.0/region_manifest.schema.json",
  "title": "RegionManifest",
  "description": "Authoring manifest for a deterministic tactical region.",
  "type": "object",
  "required": [
    "schema_version",
    "region_manifest_id",
    "region_id",
    "region_name",
    "bounds",
    "default_cell_size_m",
    "spatial_ingest_ids",
    "road_network",
    "h3_cover"
  ],
  "properties": {
    "schema_version": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/schemaVersion"
    },
    "region_manifest_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "region_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "region_name": {
      "type": "string",
      "minLength": 1
    },
    "bounds": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84BoundingBox"
    },
    "default_cell_size_m": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
    },
    "spatial_ingest_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
      }
    },
    "build_seed": {
      "type": "integer"
    },
    "road_network": {
      "$ref": "#/$defs/roadNetworkConfig"
    },
    "facilities": {
      "type": "array",
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/facility.schema.json"
      }
    },
    "asset_features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/regionAsset"
      }
    },
    "h3_cover": {
      "$ref": "#/$defs/h3CoverConfig"
    },
    "provenance_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "travelTimeDefaults": {
      "type": "object",
      "required": [
        "default_speed_kph",
        "speed_kph_by_highway",
        "intersection_penalty_seconds"
      ],
      "properties": {
        "default_speed_kph": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
        },
        "speed_kph_by_highway": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
          }
        },
        "intersection_penalty_seconds": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/nonNegativeNumber"
        }
      },
      "additionalProperties": false
    },
    "roadNetworkSource": {
      "type": "object",
      "required": [
        "ingest_id",
        "source_kind",
        "source_name",
        "source_uri"
      ],
      "properties": {
        "ingest_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "fixture_geojson",
            "osmnx"
          ]
        },
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_uri": {
          "type": "string",
          "minLength": 1
        },
        "fallback_priority": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/nonNegativeInteger"
        },
        "network_type": {
          "type": "string",
          "minLength": 1
        },
        "custom_filter": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "roadNetworkConfig": {
      "type": "object",
      "required": [
        "sources",
        "travel_time_defaults"
      ],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/roadNetworkSource"
          }
        },
        "travel_time_defaults": {
          "$ref": "#/$defs/travelTimeDefaults"
        }
      },
      "additionalProperties": false
    },
    "regionAsset": {
      "type": "object",
      "required": [
        "schema_version",
        "asset_id",
        "asset_name",
        "asset_kind",
        "geometry_type"
      ],
      "properties": {
        "schema_version": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/schemaVersion"
        },
        "asset_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "asset_name": {
          "type": "string",
          "minLength": 1
        },
        "asset_kind": {
          "type": "string",
          "minLength": 1
        },
        "geometry_type": {
          "type": "string",
          "enum": [
            "point",
            "polygon"
          ]
        },
        "point": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84Point"
        },
        "ring": {
          "type": "array",
          "minItems": 4,
          "items": {
            "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84Point"
          }
        },
        "priority_class": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/priorityClass"
        },
        "tags": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "geometry_type": {
                "const": "point"
              }
            }
          },
          "then": {
            "required": [
              "point"
            ],
            "not": {
              "required": [
                "ring"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "geometry_type": {
                "const": "polygon"
              }
            }
          },
          "then": {
            "required": [
              "ring"
            ],
            "not": {
              "required": [
                "point"
              ]
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "h3CoverConfig": {
      "type": "object",
      "required": [
        "resolution",
        "strategy"
      ],
      "properties": {
        "resolution": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "strategy": {
          "type": "string",
          "enum": [
            "explicit",
            "bounds"
          ]
        },
        "explicit_cell_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "strategy": {
                "const": "explicit"
              }
            }
          },
          "then": {
            "properties": {
              "explicit_cell_ids": {
                "minItems": 1
              }
            },
            "required": [
              "explicit_cell_ids"
            ]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
