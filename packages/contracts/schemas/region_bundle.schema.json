{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orbital-shepherd://contracts/v1.0/region_bundle.schema.json",
  "title": "RegionBundle",
  "description": "Compiled immutable tactical region artifact derived from a RegionManifest.",
  "type": "object",
  "required": [
    "schema_version",
    "region_bundle_id",
    "region_manifest_id",
    "region_id",
    "region_name",
    "bundle_fingerprint",
    "bounds",
    "spatial_ingests",
    "travel_time_defaults",
    "road_nodes",
    "road_edges",
    "facilities",
    "asset_features",
    "h3_cover",
    "traversable_node_count",
    "traversable_edge_count",
    "compilation"
  ],
  "properties": {
    "schema_version": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/schemaVersion"
    },
    "region_bundle_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "region_manifest_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "region_id": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
    },
    "region_name": {
      "type": "string",
      "minLength": 1
    },
    "bundle_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "bounds": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84BoundingBox"
    },
    "spatial_ingests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/spatial_ingest_manifest.schema.json"
      }
    },
    "travel_time_defaults": {
      "$ref": "#/$defs/travelTimeDefaults"
    },
    "road_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/roadNode"
      }
    },
    "road_edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/roadEdge"
      }
    },
    "facilities": {
      "type": "array",
      "items": {
        "$ref": "orbital-shepherd://contracts/v1.0/facility.schema.json"
      }
    },
    "asset_features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/regionAsset"
      }
    },
    "h3_cover": {
      "$ref": "#/$defs/h3Cover"
    },
    "provenance_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "traversable_node_count": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/nonNegativeInteger"
    },
    "traversable_edge_count": {
      "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/nonNegativeInteger"
    },
    "compilation": {
      "type": "object",
      "required": [
        "source_manifest_id",
        "source_manifest_schema_version",
        "source_manifest_sha256",
        "compiled_at_utc",
        "compiler_version"
      ],
      "properties": {
        "source_manifest_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "source_manifest_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "source_manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "compiled_at_utc": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/utcTimestamp"
        },
        "compiler_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "travelTimeDefaults": {
      "type": "object",
      "required": [
        "default_speed_kph",
        "speed_kph_by_highway",
        "intersection_penalty_seconds"
      ],
      "properties": {
        "default_speed_kph": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
        },
        "speed_kph_by_highway": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
          }
        },
        "intersection_penalty_seconds": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/nonNegativeNumber"
        }
      },
      "additionalProperties": false
    },
    "roadNode": {
      "type": "object",
      "required": [
        "node_id",
        "location"
      ],
      "properties": {
        "node_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "location": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84Point"
        }
      },
      "additionalProperties": false
    },
    "roadEdge": {
      "type": "object",
      "required": [
        "edge_id",
        "source_node_id",
        "target_node_id",
        "source_ingest_id",
        "road_class",
        "distance_m",
        "speed_kph",
        "travel_time_seconds",
        "oneway",
        "geometry"
      ],
      "properties": {
        "edge_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "source_node_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "target_node_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "source_ingest_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "road_class": {
          "type": "string",
          "minLength": 1
        },
        "distance_m": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
        },
        "speed_kph": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
        },
        "travel_time_seconds": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveNumber"
        },
        "oneway": {
          "type": "boolean"
        },
        "geometry": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84Point"
          }
        },
        "road_name": {
          "type": "string"
        },
        "source_edge_ref": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "regionAsset": {
      "type": "object",
      "required": [
        "schema_version",
        "asset_id",
        "asset_name",
        "asset_kind",
        "geometry_type"
      ],
      "properties": {
        "schema_version": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/schemaVersion"
        },
        "asset_id": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/namespacedId"
        },
        "asset_name": {
          "type": "string",
          "minLength": 1
        },
        "asset_kind": {
          "type": "string",
          "minLength": 1
        },
        "geometry_type": {
          "type": "string",
          "enum": [
            "point",
            "polygon"
          ]
        },
        "point": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84Point"
        },
        "ring": {
          "type": "array",
          "minItems": 4,
          "items": {
            "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/wgs84Point"
          }
        },
        "priority_class": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/priorityClass"
        },
        "tags": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "geometry_type": {
                "const": "point"
              }
            }
          },
          "then": {
            "required": [
              "point"
            ],
            "not": {
              "required": [
                "ring"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "geometry_type": {
                "const": "polygon"
              }
            }
          },
          "then": {
            "required": [
              "ring"
            ],
            "not": {
              "required": [
                "point"
              ]
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "h3Cover": {
      "type": "object",
      "required": [
        "resolution",
        "generation_strategy",
        "cell_ids",
        "cell_count"
      ],
      "properties": {
        "resolution": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "generation_strategy": {
          "type": "string",
          "enum": [
            "explicit",
            "bounds"
          ]
        },
        "cell_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cell_count": {
          "$ref": "orbital-shepherd://contracts/v1.0/common.schema.json#/$defs/positiveInteger"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
